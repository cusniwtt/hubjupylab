[Unit]
Description=HubJupyLab Service
After=network.target

[Service]
User=hubjupylab
WorkingDirectory=/home/hubjupylab
# Assumes uv is installed and we run the app using uv
ExecStart=/usr/local/bin/uv run --project /home/hubjupylab uvicorn main:app --host 0.0.0.0 --port 8080
Restart=always
RestartSec=5
Environment=PATH=/usr/bin:/usr/local/bin

[Install]
WantedBy=multi-user.target
